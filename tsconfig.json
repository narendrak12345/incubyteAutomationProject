{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "features/**/*.ts",
    "pages/**/*.ts",
    "utils/**/*.ts",
    "models/**/*.ts"

  ]
}